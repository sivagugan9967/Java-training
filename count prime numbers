import java.util.*;

public class Zoro {
    public static void main(String[] args) { 
        int n, i, j;
        int countPrime = 0;

        Scanner s = new Scanner(System.in);
        n = s.nextInt();

        for(i = 2; i <= n; i++) {  
            int count = 0;

            for(j = 1; j <= i; j++) {  
                if(i % j == 0) {
                    count++;
                }
            }

            if(count == 2) {  
                countPrime++;
            }
        }

        System.out.println(countPrime);
    }
}

