import java.util.*;

public class multiele
 {
    public static void main(String[] args)
    {
        Scanner sc = new Scanner(System.in);

        int n = sc.nextInt();  
        int product = 1;

        for (int i = 0; i < n; i++)
        {
            int num = sc.nextInt();
            product = product * num;
        }

        System.out.println(product);
    }
}
