import java.util.*;
public class digit
{
    public static void main(String[]args)
    {
        int n,i,sum;
        Scanner s=new Scanner(System.in);
        n=s.nextInt();
        sum=0;
        for (i=1;i<=n;i++)
        {
            if(i%5==0)
            {
              sum=sum+i;
               
            }
           
        } System.out.println(sum);
    }
}
